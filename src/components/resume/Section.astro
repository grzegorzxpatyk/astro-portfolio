---
export interface listItem {
    title: string;
    organisation: string;
    organisationWebsite?: string;
    timePeriod: string;
    description?: string;
    keyTechnologies?: string[];
}

type Props = {
    title: string;
    type: 'list' | 'description';
    listItems?: Array<listItem>;
    description?: string;
    isLast?: boolean;
    repeatHeader?: boolean;
};

const {
    title,
    type,
    listItems,
    description,
    isLast = false,
    repeatHeader = false,
} = Astro.props;

const wrapperClasses = [
    !isLast
        ? 'pb-8 mb-8 border-b border-b-zinc-700 dark:border-b-zinc-400 print:pb-6 print:mb-6'
        : '',
    { 'mt-4': title === 'Education' },
];
---

{
    repeatHeader && type === 'list' && listItems ? (
        <table class:list={[...wrapperClasses, 'repeating-table w-full']}>
            <thead>
                <tr>
                    <th class='text-left p-0 font-normal align-baseline'>
                        <h3 class='text-2xl mb-6 print:mb-2 font-bold'>
                            {title}
                        </h3>
                    </th>
                </tr>
            </thead>
            <tbody>
                {listItems.map((item) => (
                    <tr class='print:break-inside-avoid'>
                        <td class='p-0 pb-6 print:pb-2'>
                            <h4 class='text-lg block border-b-zinc-500 dark:border-b-zinc-800 font-semibold'>
                                {item.title}
                            </h4>
                            <div class='flex flex-row justify-between items-center text-sm mb-3 print:mb-1'>
                                <span>
                                    {item.organisationWebsite ? (
                                        <a
                                            href={item.organisationWebsite}
                                            target='_blank'
                                        >
                                            {item.organisation}
                                        </a>
                                    ) : (
                                        item.organisation
                                    )}
                                </span>
                                <span>{item.timePeriod}</span>
                            </div>
                            {item.description && (
                                <p
                                    class='text-justify print:text-sm print:leading-[1.4] print:hyphens-auto'
                                    set:html={item.description}
                                />
                            )}
                            {item.keyTechnologies && (
                                <p class='my-2 print:my-0'>
                                    Key technologies:
                                    <ul class='pl-4 list-disc print:text-base/5'>
                                        {item.keyTechnologies.map((tech) => (
                                            <li>{tech}</li>
                                        ))}
                                    </ul>
                                </p>
                            )}
                        </td>
                    </tr>
                ))}
            </tbody>
        </table>
    ) : (
        <section class:list={wrapperClasses}>
            <h3 class='text-2xl mb-6 print:mb-2 font-bold'>{title}</h3>

            {type === 'list' && listItems ? (
                listItems.map((item) => (
                    <div class='mb-6 print:mb-2 print:break-inside-avoid'>
                        <h4 class='text-lg block border-b-zinc-500 dark:border-b-zinc-800 font-semibold'>
                            {item.title}
                        </h4>
                        <div class='flex flex-row justify-between items-center text-sm mb-3 print:mb-1'>
                            <span>
                                {item.organisationWebsite ? (
                                    <a
                                        href={item.organisationWebsite}
                                        target='_blank'
                                    >
                                        {item.organisation}
                                    </a>
                                ) : (
                                    item.organisation
                                )}
                            </span>
                            <span>{item.timePeriod}</span>
                        </div>
                        {item.description && (
                            <p
                                class='text-justify print:text-sm/4'
                                set:html={item.description}
                            />
                        )}
                        {item.keyTechnologies && (
                            <p class='my-2 print:my-0'>
                                Key technologies:
                                <ul class='pl-4 list-disc print:text-base/5'>
                                    {item.keyTechnologies.map((tech) => (
                                        <li>{tech}</li>
                                    ))}
                                </ul>
                            </p>
                        )}
                    </div>
                ))
            ) : type === 'description' && description ? (
                <p class='text-justify print:text-base print:leading-[1.5] print:hyphens-auto'>{description}</p>
            ) : null}
        </section>
    )
}

<style>
    .repeating-table {
        border-collapse: collapse;
    }
</style>
